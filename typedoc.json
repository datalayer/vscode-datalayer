{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src", "webview"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "tsconfig": "tsconfig.doc.json",
  "plugin": [],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/test/**",
    "**/testing.ts"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "excludeExternals": true,
  "readme": "README.md",
  "name": "Datalayer VS Code Extension",
  "includeVersion": true,
  "disableSources": false,
  "skipErrorChecking": true,
  "treatWarningsAsErrors": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": true
  },
  "externalSymbolLinkMappings": {
    "@datalayer/agent-runtimes": {
      "IAgentRuntimesClient": "https://github.com/datalayer/agent-runtimes",
      "SdkAgentRuntimesClient": "https://github.com/datalayer/agent-runtimes",
      "AgentsMixin": "https://github.com/datalayer/agent-runtimes"
    }
  },
  "requiredToBeDocumented": [
    "Class",
    "Function",
    "Enum",
    "Interface",
    "TypeAlias",
    "Variable",
    "Method"
  ]
}
