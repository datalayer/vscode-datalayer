# === Build/dev artifacts ===
.vscode/**
.vscode-test/**
out/**
native/**
src/**
webview/**
scripts/**
dev/**
patches/**
docs/**
docs-html/**
docs-markdown/**
coverage/**
coverage-webview/**

# === Config files ===
.gitignore
.yarnrc
webpack.config.js
vitest.config.ts
vsc-extension-quickstart.md
**/tsconfig.json
**/tsconfig*.json
**/eslint.config.mjs
**/.vscode-test.*
.mypy_cache/**
**/.mypy_cache/**
commitlint.config.js
cspell.json
knip.json
.husky/**
.prettierrc
.editorconfig
typedoc.json
netlify.toml

# === Source maps (not needed at runtime) ===
**/*.map

# === TypeScript sources (only JS needed at runtime) ===
**/*.ts
!**/*.d.ts

# === Bundle artifacts (not needed at runtime) ===
dist/*.LICENSE.txt
dist/bundle-report-*.html
dist/bundle-stats-*.json

# === node_modules: exclude everything ===
node_modules/**

# --- Whitelist: webpack externals (native bindings, not bundled) ---
!node_modules/zeromq/**
!node_modules/cmake-ts/**
!node_modules/prebuild-install/**
!node_modules/ws/**
!node_modules/bufferutil/**
!node_modules/utf-8-validate/**
!node_modules/keytar/**
!node_modules/pyodide/**
!node_modules/react/**
!node_modules/react-dom/**

# --- Whitelist: externalized UI packages ---
!node_modules/lexical/**
!node_modules/@lexical/**
!node_modules/@jupyterlab/**
!node_modules/@primer/react/**
!node_modules/@vscode/codicons/dist/**

# --- Whitelist: @datalayer packages (only the ones actually used) ---
!node_modules/@datalayer/core/lib/**
!node_modules/@datalayer/core/style/**
!node_modules/@datalayer/core/schema/**
!node_modules/@datalayer/core/package.json
!node_modules/@datalayer/jupyter-react/lib/**
!node_modules/@datalayer/jupyter-react/style/**
!node_modules/@datalayer/jupyter-react/schema/**
!node_modules/@datalayer/jupyter-react/package.json
!node_modules/@datalayer/jupyter-lexical/lib/**
!node_modules/@datalayer/jupyter-lexical/style/**
!node_modules/@datalayer/jupyter-lexical/package.json
!node_modules/@datalayer/icons-react/**
!node_modules/@datalayer/lexical-loro/lib/**
!node_modules/@datalayer/lexical-loro/package.json
!node_modules/@datalayer/primer-addons/lib/**
!node_modules/@datalayer/primer-addons/style/**
!node_modules/@datalayer/primer-addons/package.json

# Exclude examples from whitelisted @datalayer packages
node_modules/@datalayer/*/lib/examples/**

# Exclude @primer/css (not imported, @primer/react is separate)
node_modules/@primer/css/**

# === Resources ===
!resources/agents/**
resources/icons/**
