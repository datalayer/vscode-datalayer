-# Get the script directory and project root
-SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
-CORE_ROOT="$( cd "$SCRIPT_DIR/.." && pwd )"
-
-cd "$CORE_ROOT"
