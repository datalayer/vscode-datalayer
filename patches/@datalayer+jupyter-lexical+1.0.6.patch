+
+/* 
+ * Adjust spacing around Jupyter cell outputs for better layout
+ * Issue: https://github.com/datalayer/jupyter-ui/issues/421
+ * 
+ * (A) Reduce gap between cell input and first output
+ * (B) Increase space between consecutive outputs for better readability
+ */
+
+/* Reduce gap between input and output wrapper (contains prompt + outputs) */
+.jp-Cell:not(.jp-mod-noOutputs) .jp-Cell-outputWrapper {
+  margin-top: 0px !important;
+}
+
+/* Reduce padding between output wrapper and first output */
+.jp-Cell-outputArea {
+  padding-top: 0px !important;
+}
+
+/* Add spacing between consecutive outputs (not the first one) */
+.jp-OutputArea-child + .jp-OutputArea-child {
+  margin-top: 12px !important;
+}
+
+/* Reduce bottom padding of output area */
+.jp-Cell-outputArea {
+  padding-bottom: 8px !important;
+}
