+                if (childFormat !== 0) {
+                    hasFormatting = true;
+                }
+            }
+            else {
+                // Nested node - recursively extract
+                const nested = extractTextAndFormatting(child);
+                if (nested.formatting) {
+                    formatting.push(...nested.formatting);
+                    hasFormatting = true;
+                }
+                else {
+                    formatting.push({ text: nested.text, format: 0 });
