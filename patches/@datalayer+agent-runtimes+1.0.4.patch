+        connect();
+        return () => {
+            disposed = true;
+            if (reconnectTimer)
+                clearTimeout(reconnectTimer);
+            agentRuntimeStore.getState().setWs(null, agentId);
+            agentRuntimeStore.getState().resetWs();
+        };
+    }, [
+        enabled,
+        baseUrl,
+        authToken,
+        agentId,
+        autoReconnect,
+        reconnectDelayMs,
+        maxReconnectAttempts,
+    ]);
