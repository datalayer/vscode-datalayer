+};
+// ============================================================================
+// Persona Definitions
+// ============================================================================
+export const CODE_PERSONA_0_0_1 = {
+    id: 'code',
+    version: '0.0.1',
+    name: 'Code',
+    description: 'A pragmatic coding companion focused on writing, reviewing and refactoring software. Pairs well with editors, terminals and code execution sandboxes.',
