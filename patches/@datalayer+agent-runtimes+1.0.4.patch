+    ws.onclose = () => {
+        entry.ws = null;
+        if (entry.disposed || entry.listeners.size === 0)
+            return;
+        entry.reconnectTimer = setTimeout(() => connectEntry(entry), 2000);
+    };
+    entry.ws = ws;
