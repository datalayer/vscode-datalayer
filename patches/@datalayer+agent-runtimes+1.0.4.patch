+    let result = name
+        .replace(/Example$/, '')
+        .replace(/([A-Z])/g, ' $1')
+        .replace(/^\s+/, '')
+        .trim();
+    for (const [pattern, replacement] of DISPLAY_NAME_EXCEPTIONS) {
