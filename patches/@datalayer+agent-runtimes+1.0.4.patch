+                category: getCategoryIndex(visualCategory),
+                value: hitCount,
+                itemStyle: hitCount > 0 ? { borderWidth: 3, borderColor: '#e3b341' } : undefined,
+                label: {
+                    show: true,
+                    fontSize: 11,
+                    color: '#c9d1d9',
+                },
+                tooltip: {
+                    formatter: () => {
+                        const lines = [
+                            `<b>${node.name}</b>`,
+                            `Category: ${node.category}`,
+                            `Executions: ${hitCount}`,
+                        ];
