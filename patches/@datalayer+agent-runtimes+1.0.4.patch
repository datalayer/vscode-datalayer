+function buildEventLookup(events) {
+    const map = new Map();
+    for (const evt of events) {
+        const existing = map.get(evt.nodeId);
+        if (existing) {
+            existing.push(evt);
+        }
+        else {
+            map.set(evt.nodeId, [evt]);
+        }
+    }
+    return map;
+}
