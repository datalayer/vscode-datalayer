+    MARKETING: 'marketing',
+    PENTEST: 'pentest',
+    PHARMA: 'pharma',
+    POIROT: 'poirot',
+    SENTINEL: 'sentinel',
+    TRADER: 'trader',
+    TUTOR: 'tutor',
