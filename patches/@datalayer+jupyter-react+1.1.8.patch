+export const insertCellsTool = {
+    name: 'datalayer_insertCells',
+    displayName: 'Insert Multiple Notebook Cells',
+    toolReferenceName: 'insertCells',
+    description: 'Inserts multiple code or markdown cells into a Jupyter notebook in a single operation. More efficient than calling insertCell multiple times.',
+    parameters: {
+        type: 'object',
+        properties: {
+            cells: {
+                type: 'array',
